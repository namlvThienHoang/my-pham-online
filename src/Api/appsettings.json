{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=beauty_ecommerce;Username=postgres;Password=postgres123;Include Error Detail=true",
    "Redis": "localhost:6379",
    "Elasticsearch": "http://localhost:9200"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "BeautyCommerce",
    "Audience": "BeautyCommerceUsers",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "AllowedHosts": [
    "http://localhost:3000",
    "http://localhost:5000"
  ],
  "Seq": {
    "Url": "http://localhost:5341"
  },
  "Elasticsearch": {
    "ProductIndex": "products",
    "NumberOfShards": 1,
    "NumberOfReplicas": 0
  },
  "Hangfire": {
    "DashboardAuthorization": "Admin"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInSeconds": 60
  },
  "ExternalServices": {
    "GHN": {
      "BaseUrl": "https://dev-online-gateway.ghn.vn/shiip/public-api/v2",
      "ApiKey": "your-ghn-api-key",
      "ShopId": "123456"
    },
    "Stripe": {
      "ApiKey": "sk_test_your_stripe_key",
      "WebhookSecret": "whsec_your_webhook_secret"
    },
    "SES": {
      "Region": "us-east-1",
      "FromEmail": "noreply@beautycommerce.com"
    },
    "SMS": {
      "Provider": "Twilio",
      "AccountSid": "your_twilio_sid",
      "AuthToken": "your_twilio_token",
      "FromNumber": "+1234567890"
    }
  },
  "OpenTelemetry": {
    "ExportEndpoint": "http://localhost:4317",
    "ServiceName": "BeautyCommerce.Api",
    "SamplingRatio": 0.01,
    "ErrorSampleRate": 1.0,
    "SlowSampleThresholdMs": 500,
    "SlowSampleRate": 0.1
  }
}
