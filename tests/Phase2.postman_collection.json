{
  "info": {
    "name": "Beauty Ecommerce Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Test User\",\n  \"phoneNumber\": \"0901234567\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders - Customer",
      "item": [
        {
          "name": "Create Order (COD)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.orderId) {",
                  "    pm.collectionVariables.set('orderId', jsonData.orderId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerNote\": \"Giao giờ hành chính\",\n  \"shippingAddressLine1\": \"123 Đường ABC\",\n  \"shippingAddressLine2\": \"Apt 4B\",\n  \"shippingWard\": \"Phường Bến Nghé\",\n  \"shippingDistrict\": \"Quận 1\",\n  \"shippingCity\": \"Hồ Chí Minh\",\n  \"shippingPostalCode\": \"70000\",\n  \"paymentMethod\": \"COD\",\n  \"voucherCode\": null,\n  \"useWalletBalance\": false\n}"
            }
          }
        },
        {
          "name": "Create Order (Stripe)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.orderId) {",
                  "    pm.collectionVariables.set('orderId', jsonData.orderId);",
                  "}",
                  "console.log('Payment URL:', jsonData.paymentUrl);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerNote\": \"Thanh toán bằng thẻ\",\n  \"shippingAddressLine1\": \"456 Đường XYZ\",\n  \"shippingWard\": \"Phường Thảo Điền\",\n  \"shippingDistrict\": \"Quận 2\",\n  \"shippingCity\": \"Hồ Chí Minh\",\n  \"paymentMethod\": \"Stripe\",\n  \"voucherCode\": null,\n  \"useWalletBalance\": false\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/orders?page=1&pageSize=10"
          }
        },
        {
          "name": "Get My Orders - Filter by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/orders?page=1&pageSize=10&status=Pending"
          }
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          }
        },
        {
          "name": "Apply Voucher to Order",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/orders/apply-voucher",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"voucherCode\": \"SAVE10\"\n}"
            }
          }
        },
        {
          "name": "Get Payment Link",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/orders/{{orderId}}/payment-link"
          }
        }
      ]
    },
    {
      "name": "Orders - Admin",
      "item": [
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/orders?page=1&pageSize=20"
          }
        },
        {
          "name": "Filter Orders by Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/orders?status=Pending&page=1"
          }
        },
        {
          "name": "Filter Orders by Date Range",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/orders?fromDate=2024-01-01&toDate=2024-12-31"
          }
        },
        {
          "name": "Search Orders",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/orders?searchTerm=user@test.com"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/api/admin/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Confirmed\",\n  \"reason\": null\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Vouchers - Admin",
      "item": [
        {
          "name": "Create Percentage Voucher",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/vouchers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SUMMER10\",\n  \"name\": \"Khuyến mãi hè 10%\",\n  \"description\": \"Giảm 10% cho đơn hàng từ 500k\",\n  \"type\": \"Percentage\",\n  \"value\": 10,\n  \"maxDiscountAmount\": 100000,\n  \"minOrderAmount\": 500000,\n  \"totalUsageLimit\": 1000,\n  \"startDate\": \"2024-06-01T00:00:00Z\",\n  \"endDate\": \"2024-08-31T23:59:59Z\",\n  \"isPublic\": true,\n  \"isStackable\": false\n}"
            }
          }
        },
        {
          "name": "Create Fixed Amount Voucher",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/vouchers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SAVE50K\",\n  \"name\": \"Giảm 50k\",\n  \"description\": \"Giảm 50,000đ cho mọi đơn hàng\",\n  \"type\": \"FixedAmount\",\n  \"value\": 50000,\n  \"maxDiscountAmount\": null,\n  \"minOrderAmount\": 200000,\n  \"totalUsageLimit\": 500,\n  \"startDate\": \"2024-01-01T00:00:00Z\",\n  \"endDate\": \"2024-12-31T23:59:59Z\",\n  \"isPublic\": true,\n  \"isStackable\": false\n}"
            }
          }
        },
        {
          "name": "Create Free Shipping Voucher",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/vouchers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"FREESHIP\",\n  \"name\": \"Miễn phí vận chuyển\",\n  \"description\": \"Freeship cho đơn từ 300k\",\n  \"type\": \"FreeShipping\",\n  \"value\": 0,\n  \"maxDiscountAmount\": null,\n  \"minOrderAmount\": 300000,\n  \"totalUsageLimit\": 2000,\n  \"startDate\": \"2024-01-01T00:00:00Z\",\n  \"endDate\": \"2024-12-31T23:59:59Z\",\n  \"isPublic\": true,\n  \"isStackable\": true\n}"
            }
          }
        },
        {
          "name": "Get All Vouchers",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/vouchers?page=1&pageSize=20"
          }
        },
        {
          "name": "Get Voucher by ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/vouchers/{{voucherId}}"
          }
        },
        {
          "name": "Update Voucher",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [],
            "url": "{{baseUrl}}/api/vouchers/{{voucherId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Voucher Name\",\n  \"value\": 15,\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Delete Voucher",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/vouchers/{{voucherId}}"
          }
        }
      ]
    },
    {
      "name": "Webhooks (Testing)",
      "item": [
        {
          "name": "Stripe Webhook - Payment Success",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Stripe-Signature", "value": "t=xxx,v1=xxx" }
            ],
            "url": "{{baseUrl}}/api/webhooks/stripe",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"pi_xxx\",\n  \"object\": \"payment_intent\",\n  \"amount\": 100000,\n  \"currency\": \"vnd\",\n  \"status\": \"succeeded\",\n  \"metadata\": {\n    \"orderId\": \"{{orderId}}\"\n  }\n}"
            }
          }
        },
        {
          "name": "PayOS Webhook - Payment Success",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/webhooks/payos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderCode\": \"{{orderId}}\",\n  \"amount\": 100000,\n  \"status\": \"PAID\",\n  \"transactionId\": \"txn_123456\",\n  \"message\": \"Thành công\"\n}"
            }
          }
        },
        {
          "name": "GHN Webhook - Status Update",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/webhooks/ghn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tracking_code\": \"GHN123456\",\n  \"status\": \"delivering\",\n  \"order_code\": 123456789\n}"
            }
          }
        }
      ]
    }
  ]
}
